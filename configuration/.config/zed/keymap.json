// Zed keymap
//
// For information on binding keys, see the Zed
// documentation: https://zed.dev/docs/key-bindings
[
  {
    "context": "Workspace",
    "bindings": {
      "cmd-t": "file_finder::Toggle",
      "cmd-e": "project_symbols::Toggle",
      "cmd-shift-a": "workspace::AddFolderToProject",
      "cmd-shift-`": null
    }
  },
  {
    "context": "Pane",
    "bindings": {
      "cmd-1": ["pane::ActivateItem", 0],
      "cmd-2": ["pane::ActivateItem", 1],
      "cmd-3": ["pane::ActivateItem", 2],
      "cmd-4": ["pane::ActivateItem", 3],
      "cmd-5": ["pane::ActivateItem", 4],
      "cmd-6": ["pane::ActivateItem", 5],
      "cmd-7": ["pane::ActivateItem", 6],
      "cmd-8": ["pane::ActivateItem", 7],
      "cmd-9": ["pane::ActivateItem", 8],
      "cmd-0": "pane::ActivateLastItem",
      "cmd-shift-t": "pane::ReopenClosedItem",
      "cmd-shift-f": "project_search::ToggleFocus"
    }
  },
  {
    "context": "Terminal",
    "bindings": {
      "cmd-q": null,
      "cmd-t": "workspace::NewTerminal",
      "cmd-shift-5": "pane::SplitDown",
      "cmd-w": ["pane::CloseActiveItem", { "close_pinned": false }]
    }
  },
  {
    "bindings": {
      "cmd-j": "terminal_panel::ToggleFocus",
      "cmd-shift-q": "zed::Quit"
    }
  }
]
